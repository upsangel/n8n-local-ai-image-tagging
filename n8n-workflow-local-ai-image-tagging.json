      ]
    },
    {
      "parameters": {
        "operation": "write",
        "exifMetadata": {
          "metadataValues": [
            {
              "name": "ImageDescription",
              "value": "={{ $json.choices[0].message.content.replace(/<think>[\\s\\S]*?<\\/think>/g, '').trim() }}"
            },
            {
              "name": "Keywords",
              "value": "={{ $json.choices[0].message.content.replace(/<think>[\\s\\S]*?<\\/think>/g, '').trim() }}"
            }
