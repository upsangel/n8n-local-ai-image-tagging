    },
    {
      "parameters": {
        "command": "rm -f /home/node/.n8n/storage/n8n-nodes-exif-data.exifData/*_exiftool_tmp"
      },
      "id": "0341ebef-7f1b-46bc-8a43-f843af6bbc9e",
      "name": "Clean Exif Temp File",
      "type": "n8n-nodes-base.executeCommand",
